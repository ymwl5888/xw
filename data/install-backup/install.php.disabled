    ['神光同步', '💡', 17],
    ['驱动工具', '🔌', 18],
];

$stmt = $db->prepare("INSERT OR IGNORE INTO categories (name, icon, sort_order) VALUES (?, ?, ?)");
foreach ($categories as $cat) {
    $stmt->execute($cat);
}

